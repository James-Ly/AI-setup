{
  "skillOverrides": {
    "create-pr": "on"
  },
  "permissions": {
    "allow": [
      "Read", "Glob", "Grep", "LS",
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npm test *)",
      "Bash(npx tsc *)",
      "Bash(npx vitest *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git push -u origin *)",
      "Bash(gh pr create *)",
      "Bash(gh pr view *)",
      "Bash(gh repo view *)",
      "Write(src/**)",
      "Edit", "MultiEdit"
    ],
    "deny": [
      "Read(.env*)",
      "Read(**/secrets/**)",
      "Write(.env*)",
      "Write(production.*)",
      "Write(.github/workflows/*)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(git push * main*)",
      "Bash(git push * master*)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git merge *)",
      "Bash(npm publish *)",
      "Bash(docker *)",
      "Bash(curl * | sh)",
      "Bash(wget *)"
    ]
  }
}